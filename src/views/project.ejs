<%- include('partials/header') %>
<main>
  <h2><%= title %></h2>

  <p>
    <strong>Description:</strong><br>
    <%= projectDetails.description %>
  </p>

  <p>
    <strong>Date:</strong><br>
    <%= new Date(projectDetails.project_date).toLocaleDateString('en-US', { year: 'numeric' , month: 'long' , day: 'numeric' }) %>
  </p>

  <p>
    <strong>Location:</strong><br>
    <%= projectDetails.location %>
  </p>

  <p>
    <strong>Partner Organization:</strong><br>
    <a href="/organization/<%= projectDetails.organization_id %>">
      <%= projectDetails.organization_name %>
    </a>
  </p>
</main>
<%- include('partials/footer') %>